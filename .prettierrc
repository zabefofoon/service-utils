{
    "semi": false,
    "tabWidth": 2,
    "useTabs": false,
    "singleQuote": false,
    "quoteProps": "as-needed",
    "jsxSingleQuote": false,
    "trailingComma": "es5",
    "bracketSpacing": true,
    "arrowParens": "always",
    "printWidth": 100,
    "vueIndentScriptAndStyle": true,
    "singleAttributePerLine": true,
    "bracketSameLine": true
}
